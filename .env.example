APP_ADDR=:8080
BASE_URL=http://localhost:8080
SITE_PUBLIC_URL=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_DRIVER=sqlite3
DB_DSN=file:./data/store.db?cache=shared&_pragma=foreign_keys(1)&_pragma=journal_mode(WAL)&_pragma=synchronous(NORMAL)&_pragma=busy_timeout(10000)
# PostgreSQL example:
# DB_DRIVER=postgres
# DB_DSN=postgres://appstore:appstore@postgres:5432/appstore?sslmode=disable
# MySQL example:
# DB_DRIVER=mysql
# DB_DSN=appstore:appstore@tcp(mysql:3306)/appstore?parseTime=true

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data/files

WEBDAV_URL=
WEBDAV_USER=
WEBDAV_PASS=
WEBDAV_PUBLIC_URL=

S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true
S3_PUBLIC_URL=

SITE_MAX_LPK_SIZE=524288000
SITE_MAX_VERSIONS=10
REQUIRE_EMAIL_VERIFY=false
SOURCE_PASSWORD=
SOURCE_PASSWORD_ROTATION=0
GITHUB_MIRROR=

SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SESSION_SECRET=change-this-session-secret
